# ─── API Keys ─────────────────────────────────────────────────
# Polygon.io — for Layer-3 minute bars (stocks / ETFs)
# Get one at https://polygon.io (Starter tier or higher for realtime)
POLYGON_API_KEY=

# Databento — optional, for SOFR/ZQ futures tick data
DATABENTO_API_KEY=

# FRED (St. Louis Fed) — for WRESBAL reserves
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─── Telegram alerts ──────────────────────────────────────────
# Create bot via @BotFather, then add it to a chat and get chat_id
# via https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Bark (iOS push) ──────────────────────────────────────────
# Install the Bark app on iPhone, copy the device key shown on the
# app's home page. Leave BARK_SERVER_URL at the default to use the
# public server, or point it at a self-hosted deployment.
BARK_DEVICE_KEY=
BARK_SERVER_URL=https://api.day.app

# ─── Paths ────────────────────────────────────────────────────
DATA_DIR=./data

# ─── Alert thresholds (all in billion USD) ────────────────────
# ANY non-zero SRP acceptance is considered CRITICAL by default
SRP_ALERT_MIN_BN=0.0

# Daily TGA swing (absolute) that triggers HIGH alert
TGA_DAILY_SWING_BN=50.0

# ON RRP daily drain threshold (negative delta)
RRP_DAILY_DRAIN_BN=50.0

# Net liquidity 7-day EWMA slope reversal (billion USD / day)
NET_LIQUIDITY_SLOPE_ALERT=-20.0

# Layer-3 proxy z-score anomaly threshold
PROXY_Z_THRESHOLD=3.0
PROXY_WINDOW_MINUTES=60

# ─── Tiered structural thresholds (playbook) ──────────────────
# Reserves floor tiers (billion USD). Below each level triggers the
# corresponding severity + an action playbook (equity reduction + hedge size).
RESERVES_MEDIUM_BN=3200
RESERVES_HIGH_BN=3000
RESERVES_CRITICAL_BN=2800

# ON RRP cushion tiers (billion USD).
RRP_MEDIUM_BN=200
RRP_HIGH_BN=100
RRP_CRITICAL_BN=50

# Net Liquidity (Reserves + RRP − TGA) absolute-level tiers (billion USD).
# Calibrated for POST-QT regime (~$2.3T baseline). Revise up by ~$2T if Fed
# resumes QE.
NET_LIQ_MEDIUM_BN=2400
NET_LIQ_HIGH_BN=2200
NET_LIQ_CRITICAL_BN=2000

# Default hedge ticker for action playbook. Options: SPY | QQQ | IWM.
HEDGE_TICKER=SPY

# ─── Market stress (Layer-2 fast pulse) ───────────────────────
# Composite stress z-score thresholds for the ETF + VIX basket polled
# every 15 min during US market hours via yfinance.
MARKET_STRESS_MEDIUM_Z=2.0
MARKET_STRESS_HIGH_Z=3.0
MARKET_STRESS_CRITICAL_Z=4.0

# ─── 30Y auction tail (leading indicator) ─────────────────────
# (clearing high yield − prior-day DGS30 close) in basis points.
# Normal: 0-1 bp. 2018 Q4 / 2023 Oct stress events: > 6 bp.
AUCTION_TAIL_MEDIUM_BP=2.0
AUCTION_TAIL_HIGH_BP=4.0
AUCTION_TAIL_CRITICAL_BP=6.0

# ─── Operational ──────────────────────────────────────────────
INITIAL_POLL_ON_START=true
LOG_LEVEL=INFO
