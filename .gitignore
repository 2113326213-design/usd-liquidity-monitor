# ─── Secrets ─────────────────────────────────────
# NEVER commit real .env — it holds API keys
.env
.env.local
.env.*.local

# ─── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Virtualenv ──────────────────────────────────
.venv/
venv/
env/

# ─── Runtime data (regenerated by collectors) ────
# Parquet snapshots are refetched from FRED / NY Fed on startup.
# Logs rotate daily.
data/raw/*.parquet
data/raw/proxy/*
data/derived/*.parquet
data/logs/*.log
data/logs/*.log.*
data/state/
data/*.db
data/*.sqlite

# ─── IDE / OS ────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# ─── Build / dist ────────────────────────────────
build/
dist/
*.egg

# ─── Misc ────────────────────────────────────────
*.log
.coverage
htmlcov/
